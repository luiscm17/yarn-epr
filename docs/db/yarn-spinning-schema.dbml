// DB Schema: Yarn Spinning
// Source: docs/prd/operation/yarn-spinning.md
// Stack: PostgreSQL 15

// ============================================================
// SHARED CATALOGS
// ============================================================

Table employees {
  employee_id integer [pk]
  full_name varchar(150)
  role varchar(30)
  is_active boolean
}

Table shifts {
  shift_code varchar(1) [pk]
  shift_name varchar(20)
}

Table yarn_counts {
  yarn_count_id integer [pk]
  yarn_count_name varchar(30) [unique]
  material_type varchar(10)
  dtex decimal(8,2)
}

Table sections {
  section_id integer [pk]
  section_name varchar(50)
  has_advance boolean
  production_recorded_by varchar(20)  // Quality, Inventory, Unassigned
  advance_recorded_by varchar(20)     // Quality, Inventory, Unassigned
  quality_method varchar(20)        // Samples, BodyKmCuts, RandomCheck
}

Table machine_groups {
  machine_group_id integer [pk]
  machine_group_name varchar(50)
  section_id integer [ref: > sections.section_id]
}

// Natural key: machine code IS the PK (PSJ-1B, FIN-A, etc.)
Table machines {
  machine_id varchar(20) [pk]
  section_id integer [ref: > sections.section_id]
  machine_type varchar(10)  // PSJ, FIN, or null
  machine_group_id integer [ref: > machine_groups.machine_group_id]
  is_active boolean [default: true]
}

// ============================================================
// TRANSACTION TABLES
// ============================================================

Table production_discharges {
  production_discharge_id integer [pk]
  machine_id varchar(20) [ref: > machines.machine_id]
  shift_code varchar(1) [ref: > shifts.shift_code]
  date date
  section_id integer [ref: > sections.section_id]
  yarn_count_id integer [ref: > yarn_counts.yarn_count_id]
  supervisor_id integer [ref: > employees.employee_id]
  foreman_id integer [ref: > employees.employee_id]
  gross_weight_kg decimal(8,2)
  spindle_count integer
  tare_per_spindle_g decimal(6,2)
  carriage_weight_kg decimal(6,2)
  net_weight_kg decimal(8,2)
  comments text
  edit_version integer [default: 1]
  created_at timestamptz [default: `now()`]

  indexes {
    (machine_id, date, shift_code) [name: idx_prod_machine_date]
    (section_id, date) [name: idx_prod_section_date]
  }
}

Table skeining_productions {
  skeining_production_id integer [pk]
  machine_id varchar(20) [ref: > machines.machine_id]
  shift_code varchar(1) [ref: > shifts.shift_code]
  date date
  section_id integer [ref: > sections.section_id]
  yarn_count_id integer [ref: > yarn_counts.yarn_count_id]
  supervisor_id integer [ref: > employees.employee_id]
  foreman_id integer [ref: > employees.employee_id]
  num_skeins integer
  weight_per_skein_g decimal(6,2)
  net_weight_kg decimal(8,2)
  operator_name varchar(100)
  comments text
  edit_version integer [default: 1]
  created_at timestamptz [default: `now()`]

  indexes {
    (machine_id, date, shift_code) [name: idx_skn_machine_date]
    (section_id, date) [name: idx_skn_section_date]
  }
}

Table advance_trackings {
  advance_tracking_id integer [pk]
  machine_id varchar(20) [ref: > machines.machine_id]
  shift_code varchar(1) [ref: > shifts.shift_code]
  date date
  section_id integer [ref: > sections.section_id]
  yarn_count_id integer [ref: > yarn_counts.yarn_count_id]
  supervisor_id integer [ref: > employees.employee_id]
  foreman_id integer [ref: > employees.employee_id]
  sample_gross_weight_g decimal(6,2)
  sample_tare_weight_g decimal(6,2)
  spindle_count integer
  weight_input_kg decimal(8,2)
  weight_output_kg decimal(8,2)
  weight_download_kg decimal(8,2)
  working_hours decimal(4,1)
  comments text
  edit_version integer [default: 1]
  created_at timestamptz [default: `now()`]

  indexes {
    (machine_id, date, shift_code) [name: idx_adv_machine_date]
    (section_id, date) [name: idx_adv_section_date]
    (machine_id, shift_code, date, yarn_count_id) [unique, name: idx_adv_unique_turn]
  }
}

// RandomCheck = Quality inspector chooses machines, NOT the system
Table quality_controls {
  quality_control_id integer [pk]
  machine_id varchar(20) [ref: > machines.machine_id]
  shift_code varchar(1) [ref: > shifts.shift_code]
  date date
  section_id integer [ref: > sections.section_id]
  yarn_count_id integer [ref: > yarn_counts.yarn_count_id]
  inspector_id integer [ref: > employees.employee_id]
  method varchar(20)  // Samples, BodyKmCuts, RandomCheck
  sample_values jsonb  // Array of values (Samples)
  cv_percent decimal(5,2)  // Samples
  tenacity decimal(5,2)  // Samples
  elongation decimal(5,2)  // Samples
  body_value decimal(8,2)  // BodyKmCuts
  kilometers_processed decimal(8,2)  // BodyKmCuts
  cuts_per_cone decimal(6,2)  // BodyKmCuts
  results jsonb  // Flexible. RandomCheck: user records whatever they test
  comments text
  edit_version integer [default: 1]
  created_at timestamptz [default: `now()`]

  indexes {
    (machine_id, date, shift_code) [name: idx_qlty_machine_date]
    (section_id, date) [name: idx_qlty_section_date]
  }
}

Table waste_records {
  waste_record_id integer [pk]
  machine_group_id integer [ref: > machine_groups.machine_group_id]
  section_id integer [ref: > sections.section_id]
  shift_code varchar(1) [ref: > shifts.shift_code]
  date date
  weight_kg decimal(8,2)
  waste_type varchar(20)  // Actual, Accumulated
  registered_by_id integer [ref: > employees.employee_id]
  comments text
  edit_version integer [default: 1]
  created_at timestamptz [default: `now()`]

  indexes {
    (section_id, date) [name: idx_waste_section_date]
    (machine_group_id, date) [name: idx_waste_group_date]
  }
}
