Project yarn_epr_warehouse {
  database_type: "PostgreSQL"
  Note: "Minimal Warehouse write model. Raw material is bale-centered in one table, with current Warehouse quantity and the basic Operation delivery facts needed now. No SQL is defined here."
}

Enum finished_product_delivery_type {
  direct_sale
  commercialization_transfer
}

Enum product_availability_state {
  available
  flagged
  available_with_condition
  defective
  delivered
}

Enum raw_material_custody_state {
  in_warehouse
  partially_delivered_to_operation
  delivered_to_operation
  adjusted
}

Table production_identities {
  production_identity_id uuid [pk]
  lot_code varchar [not null, unique, note: "Visible business code shared across contexts; not the technical ID."]
  target_yarn_count varchar [not null, note: "Snapshot of the requested yarn count/title for production identity."]
  required_color varchar
  destination_name varchar [note: "Business customer or destination defined for production."]
  production_variant varchar
  request_notes text
  business_defined_at timestamptz [not null]
  defined_by_user_id uuid [not null, note: "Reference to Access/Shared actor identity; Warehouse does not own users."]
  authorized_by_user_id uuid
  created_at timestamptz [not null]
}

Table raw_material {
  raw_material_id uuid [pk]
  bale_number varchar [not null, unique, note: "Visible bale/fardo identity under Warehouse custody; not the technical ID."]
  raw_material_type varchar [not null]
  yarn_count_label varchar [note: "Snapshot of title/yarn-count wording known at reception."]
  color_or_fiber varchar
  receipt_number varchar [note: "Visible Warehouse receipt reference when one exists; no separate receipt header until needed."]
  business_received_at timestamptz [not null, note: "Physical/business receipt time, not system capture time."]
  supplier_name varchar
  received_weight_kg decimal [not null]
  current_warehouse_weight_kg decimal [not null, note: "Quantity currently available under Warehouse custody."]
  delivered_to_operation_weight_kg decimal [not null, note: "Total quantity already delivered to Operation from this bale."]
  custody_state raw_material_custody_state [not null]
  production_identity_id uuid [ref: > production_identities.production_identity_id, note: "Set only when this bale is delivered or reserved for a production identity."]
  delivered_to_operation_at timestamptz [note: "Business time of the latest delivery to Operation; enough for the current Warehouse need."]
  delivered_by_user_id uuid
  operation_received_by_user_id uuid
  received_by_user_id uuid [not null]
  condition_notes text
  created_at timestamptz [not null]
}

Table supply_items {
  supply_item_id uuid [pk]
  supply_code varchar [not null, unique]
  supply_name varchar [not null]
  supply_category varchar [not null, note: "Flexible Warehouse-owned label; no separate catalog until the source docs require one."]
  unit_of_measure varchar [not null]
  is_active boolean [not null]
  created_at timestamptz [not null]
}

Table finished_product_receipts {
  finished_product_receipt_id uuid [pk]
  receipt_number varchar [not null, unique]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "Warehouse receives the finished product under the existing shared production identity; this does not create a second product identity."]
  operation_lot_id uuid [note: "External Lot Processing technical ID when supplied; Warehouse references but does not own it."]
  operation_quality_state varchar [note: "Snapshot/reference wording reported by Operation; not Warehouse availability."]
  availability_state product_availability_state [not null, note: "Current Warehouse availability state after reception and verification."]
  physical_presentation varchar [not null, note: "Physical form received or stored by Warehouse, kept separate from availability state."]
  accepted_weight_kg decimal [not null, note: "Quantity accepted at Warehouse reception from Operation."]
  business_received_at timestamptz [not null]
  received_by_user_id uuid [not null]
  origin_supervisor_user_id uuid
  delivery_condition_note text
  verification_notes text
  created_at timestamptz [not null]
}

Table finished_product_deliveries {
  finished_product_delivery_id uuid [pk]
  delivery_number varchar [not null, unique]
  delivery_type finished_product_delivery_type [not null]
  finished_product_receipt_id uuid [not null, ref: > finished_product_receipts.finished_product_receipt_id]
  business_delivered_at timestamptz [not null]
  delivered_to_name varchar [not null, note: "Customer, Commercialization, or other business destination."]
  quantity_kg decimal [not null]
  commercial_document_number varchar [note: "Invoice or commercial reference when applicable."]
  handled_by_user_id uuid [not null]
  authorized_by_user_id uuid
  notes text
  created_at timestamptz [not null]
}

Table finished_product_returns {
  finished_product_return_id uuid [pk]
  finished_product_receipt_id uuid [not null, ref: > finished_product_receipts.finished_product_receipt_id, note: "Finished product returned to Warehouse availability."]
  business_returned_at timestamptz [not null, note: "Business return time; return restores the previous availability state."]
  received_by_user_id uuid [not null, note: "Warehouse user who received the returned finished product."]
  created_at timestamptz [not null]
}

Table supply_receipts {
  supply_receipt_id uuid [pk]
  receipt_number varchar [not null, unique]
  supply_item_id uuid [not null, ref: > supply_items.supply_item_id]
  business_received_at timestamptz [not null]
  received_from_name varchar [not null, note: "Supplier or source name; intentionally denormalized until a supplier catalog is justified."]
  quantity decimal [not null]
  unit_of_measure_snapshot varchar [not null]
  received_by_user_id uuid [not null]
  notes text
  created_at timestamptz [not null]
}

Table supply_deliveries {
  supply_delivery_id uuid [pk]
  delivery_number varchar [not null, unique]
  supply_item_id uuid [not null, ref: > supply_items.supply_item_id]
  business_delivered_at timestamptz [not null]
  delivered_to_name varchar [not null, note: "Person, area, or production destination that received the supply."]
  quantity decimal [not null]
  unit_of_measure_snapshot varchar [not null]
  delivered_by_user_id uuid [not null]
  received_by_name varchar [note: "Visible recipient name when no user account or catalog entry exists yet."]
  notes text
  created_at timestamptz [not null]
}

Table record_corrections {
  record_correction_id uuid [pk]
  record_table varchar [not null]
  record_id uuid [not null]
  corrected_by_user_id uuid [not null]
  corrected_at timestamptz [not null]
  correction_reason text [not null]
  authorization_basis text
  before_values jsonb [not null]
  after_values jsonb [not null]
}
