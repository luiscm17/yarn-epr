// Batch Processing context only.
// This DBML models the Lot Processing write model and its auditability.
// It intentionally references Warehouse and Yarn Spinning identities without absorbing their internals.

Project batch_processing {
  database_type: 'PostgreSQL'
  Note: 'Canonical Batch Processing schema artifact. External catalogs, employee refs, Warehouse refs, and Yarn Spinning refs stay as reference fields until their owning contexts are modeled.'
}

Enum lot_stage_kind {
  inventory_stage
  dyeing
  drying
  winding
  balling
  bagging
  quality_stage
}

Enum lot_output_route {
  winding
  balling
}

Enum lot_stage_record_state {
  active
  corrected
  voided
}

Enum stage_note_kind {
  note
  inconvenience
  delay
  validation_issue
  quality_observation
}

Enum waste_measure_basis {
  weight_only
  count_only
  weight_and_count
}

Enum lot_quality_classification {
  standard
  special_nomenclature
  flagged
}

Enum audit_action_type {
  create
  correct
  cancel
  reopen
}

Table lots {
  id uuid [pk]
  lot_code varchar [not null, unique, note: 'Visible lot code defined by Warehouse and shared across contexts. Not the technical primary key.']
  production_identity_id uuid [not null, note: 'Warehouse production identity technical ID. Batch Processing consumes it but does not own it.']
  material_emission_id uuid [note: 'Warehouse material emission technical ID when the lot is assembled from a specific emitted movement.']
  source_skein_reference_snapshot jsonb [note: 'Reference snapshot to upstream skein availability or source evidence from Yarn Spinning.']
  yarn_count_snapshot varchar [not null]
  color_requirement_snapshot varchar
  client_or_destination_snapshot varchar
  order_requirements_snapshot text
  planned_output_route lot_output_route [note: 'Operational route selected after drying: winding or balling.']
  current_stage_kind lot_stage_kind [not null, default: 'inventory_stage']
  current_stage_record_id uuid [note: 'Current active stage record for fast navigation.']
  delivered_to_warehouse_at timestamp [note: 'System/domain timestamp when the lot handoff to Warehouse was registered.']
  closed_at timestamp [note: 'Set when the lot lifecycle in Batch Processing is complete.']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Physical lot aggregate owned by Batch Processing. The physical lot is born when Inventory stage creates the first stage record, while the production identity and lot code come from Warehouse.'

  Indexes {
    (production_identity_id)
    (current_stage_kind)
  }
}

Table lot_stage_records {
  id uuid [pk]
  lot_id uuid [not null]
  stage_kind lot_stage_kind [not null]
  stage_sequence smallint [not null, note: 'Expected order: Inventory stage=1, Dyeing=2, Drying=3, Winding/Balling=4, Bagging=5, Quality stage=6.']
  record_state lot_stage_record_state [not null, default: 'active']
  business_date date [not null, note: 'Operational business date entered by the user. Separate from system timestamps.']
  business_shift_ref varchar [not null, note: 'External/shared shift reference selected operationally.']
  entered_stage_at timestamp [note: 'Operational entry datetime when the lot physically entered the stage, if captured.']
  exited_stage_at timestamp [note: 'Operational exit datetime when the lot physically left the stage, if captured.']
  received_by_actor_ref uuid [note: 'External/shared actor reference for the person responsible for receiving/working the stage.']
  handed_off_by_actor_ref uuid [note: 'External/shared actor reference for the person handing off the lot from this stage.']
  supervisor_actor_ref uuid [note: 'External/shared supervisor reference.']
  inherited_data_snapshot jsonb [note: 'Data inherited from Warehouse or the previous stage. Example: lot code, yarn count, prior counts, prior output condition.']
  locally_verified_data_snapshot jsonb [note: 'Data verified or measured locally by the current stage. Keep distinct from inherited data.']
  stage_generated_data_snapshot jsonb [note: 'Stage-local data created here, such as tina number, temperature, produced cone count, bag usage, or stage-specific observations.']
  output_condition_snapshot jsonb [note: 'Condition in which the lot leaves this stage toward the next one.']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Single-stage-record model. Each stage contributes one owned record to the unified lot history instead of separate enter/exit documents. Exactly one of winding or balling should exist for a given lot route.'

  Indexes {
    (lot_id, stage_sequence) [unique]
    (lot_id, stage_kind) [unique]
    (business_date, business_shift_ref)
  }
}

Table lot_stage_record_notes {
  id uuid [pk]
  lot_stage_record_id uuid [not null]
  note_kind stage_note_kind [not null]
  category_ref varchar [note: 'External/shared category reference. Stage-specific inconvenience and defect catalogs remain outside this context schema.']
  detail text
  reported_by_actor_ref uuid [note: 'External/shared actor reference.']
  created_at timestamp [not null]

  Note: 'Structured notes, inconveniences, delays, and categorized exceptions attached to one stage record.'

  Indexes {
    (lot_stage_record_id)
    (category_ref)
  }
}

Table lot_stage_record_waste {
  id uuid [pk]
  lot_stage_record_id uuid [not null]
  waste_category_ref varchar [note: 'External/shared waste or cause vocabulary reference.']
  measure_basis waste_measure_basis [not null]
  waste_weight_kg decimal(12,3)
  waste_unit_count decimal(12,3)
  waste_unit_label varchar [note: 'Examples: skein, cone, ball, bag.']
  detail text
  recorded_by_actor_ref uuid [note: 'External/shared actor reference.']
  created_at timestamp [not null]

  Note: 'Stage waste kept inside the lot history. Supports weight, count, or both because the exact business measurement varies by stage.'

  Indexes {
    (lot_stage_record_id)
    (waste_category_ref)
  }
}

Table lot_quality_outcomes {
  id uuid [pk]
  lot_id uuid [not null, unique]
  quality_stage_record_id uuid [not null, unique]
  quality_classification lot_quality_classification [not null]
  special_nomenclature varchar [note: 'Used only when Quality stage applies a special nomenclature.']
  visual_defects_snapshot jsonb [note: 'Structured defect evidence captured by Quality stage.']
  internal_defects_snapshot jsonb [note: 'Structured internal-defect evidence captured by Quality stage.']
  delivery_condition_snapshot jsonb [note: 'Condition in which the lot is delivered to Warehouse. This documents the handoff condition but does not decide Warehouse disposition.']
  operation_resolution_note text [note: 'Optional note for actions or decisions exhausted within Batch Processing before delivery.']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Final Batch Processing quality outcome owned by the Quality stage. Warehouse later decides warehouse availability/disposition separately.'
}

Table lot_delivery_handoffs {
  id uuid [pk]
  lot_id uuid [not null, unique]
  quality_outcome_id uuid [not null, unique]
  handoff_number varchar [unique, note: 'Visible Batch Processing handoff reference if the process needs one.']
  business_date date [not null]
  business_shift_ref varchar [not null, note: 'Operational shift at handoff time.']
  delivered_at timestamp [not null, note: 'Physical handoff datetime to Warehouse.']
  delivered_by_actor_ref uuid [note: 'External/shared actor reference from Batch Processing.']
  received_by_actor_ref uuid [note: 'External/shared actor reference from Warehouse when captured.']
  handoff_condition_snapshot jsonb [note: 'Operational packaging/delivery condition evidence sent with the lot.']
  handoff_note text
  warehouse_finished_product_reception_id uuid [note: 'Optional Warehouse finished-product reception technical ID once linked.']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Batch Processing handoff evidence for delivery back to Warehouse. Keeps the lot history continuous without taking ownership of Warehouse reception or disposition records.'
}

Table batch_processing_correction_audit {
  id uuid [pk]
  target_table varchar [not null]
  target_record_id uuid [not null]
  action_type audit_action_type [not null]
  correction_reason text [not null]
  authorization_ref uuid [note: 'External/shared authorization scope or override reference when relevant.']
  changed_by_actor_ref uuid [not null, note: 'External/shared actor reference.']
  changed_fields jsonb [note: 'Field-level diff metadata.']
  before_payload jsonb
  after_payload jsonb
  changed_at timestamp [not null]

  Note: 'Cross-cutting correction audit for Batch Processing records. Supports editable current business truth with mandatory audit trail.'

  Indexes {
    (target_table, target_record_id)
    (changed_at)
  }
}

Ref: lot_stage_records.lot_id > lots.id
Ref: lots.current_stage_record_id > lot_stage_records.id

Ref: lot_stage_record_notes.lot_stage_record_id > lot_stage_records.id
Ref: lot_stage_record_waste.lot_stage_record_id > lot_stage_records.id

Ref: lot_quality_outcomes.lot_id > lots.id
Ref: lot_quality_outcomes.quality_stage_record_id > lot_stage_records.id

Ref: lot_delivery_handoffs.lot_id > lots.id
Ref: lot_delivery_handoffs.quality_outcome_id > lot_quality_outcomes.id
