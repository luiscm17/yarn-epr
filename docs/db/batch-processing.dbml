Project yarn_epr_batch_processing {
  database_type: "PostgreSQL"
  Note: "Minimal Lot Processing write model. Warehouse defines the single lot identity; each specialized stage table records the history of its interventions for that same lot. Separate stage tables capture the materially different facts of Inventory, Dyeing, Drying, Winding/Balling, Bagging, and Quality. Business date, shift, actors, and timestamps describe history and never make a stage record unique. Later stages require prior-stage completion as a use-case/domain invariant; no cross-table DBML constraint models that ordering. Notes are optional fields on the stage records. Waste stays on the stages that can produce it. No SQL is defined here."
}

Enum conversion_variant {
  winding
  balling
}

Enum lot_quality_state {
  standard
  special_nomenclature
  flagged
}

Table inventory_stage_records {
  inventory_stage_record_id uuid [pk]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "The Warehouse-defined lot to which Inventory appends one or more assembly-history records."]
  business_date date [not null]
  shift_code varchar [not null]
  assembled_by_user_id uuid [not null]
  supervisor_user_id uuid [not null]
  skein_count int [not null, note: "Final number of skeins physically assembled into the lot."]
  total_weight_kg decimal [not null, note: "Weight of the assembled physical lot."]
  assembly_issue_category varchar [note: "Examples: insufficient skeins, weight out of range, incomplete emission data."]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table dyeing_stage_records {
  dyeing_stage_record_id uuid [pk]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "The Warehouse-defined lot to which Dyeing appends one or more history records."]
  business_date date [not null]
  shift_code varchar [not null]
  received_by_user_id uuid [not null]
  delivered_by_user_id uuid
  supervisor_user_id uuid [not null]
  received_skein_count int [not null]
  inherited_weight_kg decimal [note: "Weight inherited from Inventory when Dyeing does not measure it locally."]
  measured_weight_kg decimal [note: "Set only when Dyeing actually measures the lot."]
  vat_number varchar [not null]
  process_temperature decimal
  requires_redye boolean [not null]
  issue_category varchar [note: "Examples: redye, temperature out of range, contaminated vat, incorrect material."]
  output_condition_note text
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table drying_stage_records {
  drying_stage_record_id uuid [pk]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "The Warehouse-defined lot to which Drying appends one or more history records."]
  business_date date [not null]
  shift_code varchar [not null]
  received_by_user_id uuid [not null]
  delivered_by_user_id uuid
  supervisor_user_id uuid [not null]
  received_skein_count int [not null]
  measured_input_weight_kg decimal [note: "Set only when Drying actually weighs the lot; do not simulate measurements."]
  moisture_issue_category varchar [note: "Examples: excessive humidity, weight out of range."]
  output_condition_note text
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table winding_stage_records {
  winding_stage_record_id uuid [pk]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "The Warehouse-defined lot to which Winding/Balling appends one or more history records."]
  business_date date [not null]
  shift_code varchar [not null]
  received_by_user_id uuid [not null]
  delivered_by_user_id uuid
  supervisor_user_id uuid [not null]
  conversion_variant conversion_variant [not null, note: "Winding produces cones; balling produces balls."]
  received_skein_count int [not null]
  produced_unit_count int [not null, note: "Number of cones or balls produced, depending on conversion_variant."]
  waste_quantity decimal [note: "Stage-owned waste from conversion, when captured."]
  waste_unit varchar [note: "kg, units, or another explicit unit used by the business for this stage."]
  waste_cause varchar
  issue_category varchar [note: "Examples: damaged cones, incorrect yarn count, uncalibrated equipment, excessive waste."]
  output_condition_note text
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table bagging_stage_records {
  bagging_stage_record_id uuid [pk]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "The Warehouse-defined lot to which Bagging appends one or more history records."]
  business_date date [not null]
  shift_code varchar [not null]
  received_by_user_id uuid [not null]
  delivered_by_user_id uuid
  supervisor_user_id uuid [not null]
  received_unit_count int [not null, note: "Cones or balls received from Winding/Balling."]
  bag_count int [not null]
  units_per_bag int [not null]
  waste_quantity decimal [note: "Stage-owned waste from bagging, when captured."]
  waste_unit varchar [note: "kg, units, or another explicit unit used by the business for this stage."]
  waste_cause varchar
  issue_category varchar [note: "Examples: damaged bags, incorrect label, count mismatch."]
  output_condition_note text
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table lot_quality_records {
  lot_quality_record_id uuid [pk]
  production_identity_id uuid [not null, ref: > production_identities.production_identity_id, note: "The Warehouse-defined lot to which Quality appends one or more inspection records. At most one record for this identity may carry the Quality Send marker."]
  business_date date [not null]
  shift_code varchar [not null]
  inspected_by_user_id uuid [not null]
  supervisor_user_id uuid [not null]
  visual_defect_categories text [note: "Business categories such as double tone, stained, varilla, damaged skeins, tails, flames, low/high twist, or mixture."]
  internal_defect_categories text [note: "Business categories such as purged, paraffined, ficha, double strand, bad ties, tie count issues, or contamination."]
  quality_state lot_quality_state [not null, note: "Quality state reported by Operation at handoff; Warehouse availability remains separate."]
  special_nomenclature varchar [note: "Set when Quality assigns a special nomenclature under current policy."]
  delivery_condition_note text [note: "Conditions reported to Warehouse when the lot is flagged or delivered with relevant context."]
  quality_sent_to_warehouse_at timestamptz [note: "Exact audit timestamp and explicit Quality Send marker. It is set on at most one Quality record per production_identity_id; business_date may be shown in the UI but does not replace this value."]
  quality_sent_to_warehouse_by_user_id uuid [note: "Quality actor who performed the singular Quality Send."]
  warehouse_note text [note: "Brief Warehouse coordination note on this singular sent handoff while no Warehouse receipt exists for the same production_identity_id. It does not mean acceptance, change the lot identity, or create another send."]
  noted_by_user_id uuid [note: "Warehouse actor who recorded warehouse_note; this audit fact is not a permission source."]
  warehouse_noted_at timestamptz [note: "Business time when Warehouse recorded warehouse_note."]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz

  Note: "PostgreSQL enforcement required outside DBML: CREATE UNIQUE INDEX lot_quality_records_one_quality_send_per_lot_idx ON lot_quality_records (production_identity_id) WHERE quality_sent_to_warehouse_at IS NOT NULL; DBML cannot express a partial unique index."
}

Table batch_processing_record_corrections {
  correction_id uuid [pk]
  record_table varchar [not null, note: "Name of the Batch Processing table whose current business record was corrected."]
  record_id uuid [not null]
  corrected_by_user_id uuid [not null]
  corrected_at timestamptz [not null]
  correction_reason text [not null]
  authorization_basis varchar [note: "Operational window, SysAdmin override, or other policy basis."]
  before_values jsonb [not null]
  after_values jsonb [not null]
  created_at timestamptz [not null]
}
