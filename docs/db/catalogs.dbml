Project yarn_epr_catalogs {
  database_type: "PostgreSQL"
  Note: "Minimal shared Catalogs write model. This is not a generic catalog framework; it starts only with shared identities that are already justified across operational records. No SQL is defined here."
}

Table yarn_counts {
  yarn_count_id uuid [pk]
  yarn_count_code varchar [not null, unique, note: "Visible yarn count/title designation used by the business, such as 2/18 or 2/32."]
  material_type varchar [not null, note: "Business material type associated with this yarn count identity."]
  dtex decimal [note: "Technical linear-density characteristic when known or needed."]
  business_label varchar [note: "Optional business-facing label when users need wording different from the yarn count code."]
  is_active boolean [not null, note: "Controls whether the yarn count can be selected for new records without deleting history."]
  created_at timestamptz [not null]
  updated_at timestamptz
}
