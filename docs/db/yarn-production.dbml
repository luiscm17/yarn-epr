Project yarn_epr_yarn_production {
  database_type: "PostgreSQL"
  Note: "Minimal Yarn Production write model. Hybrid, but primarily record-centered: production, progress, process quality, waste, and skein output are business records. Yarn count is referenced as a shared identity from Catalogs. No production run, machine-shift context, lot aggregate, or lot timeline is modeled here. No SQL is defined here."
}

Enum yarn_spinning_section {
  preparation
  ring_spinning
  bobbin_winding
  twisting
  skeining
}

Enum process_quality_method {
  samples
  machine_counters
  random_check
}

Enum waste_record_type {
  real
  accumulated
}

Table yarn_production_machines {
  machine_id uuid [pk]
  section yarn_spinning_section [not null]
  machine_code varchar [not null, unique, note: "Visible plant machine code, such as FIN-A or a ring-spinning frame code."]
  machine_name varchar
  is_active boolean [not null]
  created_at timestamptz [not null]
}

Table production_discharges {
  production_discharge_id uuid [pk]
  section yarn_spinning_section [not null, note: "Only Preparation FIN machines, Ring Spinning, Bobbin Winding, and Twisting use this table. Skeining uses skein_records."]
  machine_id uuid [not null, ref: > yarn_production_machines.machine_id]
  business_date date [not null, note: "Operational date entered by the user; not inferred from created_at."]
  shift_code varchar [not null]
  supervisor_user_id uuid [not null]
  yarn_count_id uuid [not null, ref: > yarn_counts.yarn_count_id, note: "Shared Catalogs identity for the produced yarn count/title."]
  discharged_at timestamptz [note: "Physical discharge time when captured. The system may still record it at shift close."]
  gross_weight_kg decimal [not null]
  spindle_tare_kg decimal [not null]
  operative_spindle_count int [not null]
  cart_weight_kg decimal [not null]
  net_weight_kg decimal [not null, note: "Calculated business result preserved on the record for review and reporting."]
  roving_count int [note: "Preparation-specific count when the business captures number of mechas."]
  registered_by_user_id uuid [not null]
  registered_role varchar [not null, note: "Current registrar role snapshot; permissions remain configurable outside this DBML."]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table skein_records {
  skein_record_id uuid [pk]
  machine_id uuid [not null, ref: > yarn_production_machines.machine_id, note: "Must belong to the Skeining/Madejeras section."]
  business_date date [not null]
  shift_code varchar [not null]
  supervisor_user_id uuid [not null]
  yarn_count_id uuid [not null, ref: > yarn_counts.yarn_count_id, note: "Shared Catalogs identity for the produced yarn count/title."]
  skein_count int [not null, note: "Primary production quantity for Madejeras."]
  unit_skein_weight_kg decimal [not null, note: "Estimated weight per skein or agreed business unit for the yarn count at capture time."]
  estimated_weight_kg decimal [not null, note: "Calculated from skein count and unit weight; no spindle/tare calculation applies."]
  weight_requirement_note text [note: "Explains title-specific weight variation, for example 500g vs 600g skeins."]
  registered_by_user_id uuid [not null]
  registered_role varchar [not null]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table progress_records {
  progress_record_id uuid [pk]
  section yarn_spinning_section [not null, note: "Only Preparation, Ring Spinning, and Twisting register progress records."]
  machine_id uuid [not null, ref: > yarn_production_machines.machine_id]
  business_date date [not null]
  shift_code varchar [not null]
  yarn_count_id uuid [not null, ref: > yarn_counts.yarn_count_id, note: "Shared Catalogs identity used to reconcile progress with production discharges."]
  input_weight_kg decimal [not null]
  in_machine_net_weight_kg decimal [note: "Used by Ring Spinning and Twisting when the section captures material still in machine."]
  discharged_weight_kg decimal [not null, note: "Must reconcile with production discharge totals for the same section, machine, shift, date, and yarn count identity."]
  output_weight_kg decimal [not null]
  operative_spindle_count int [note: "Used where progress is calculated by spindle sampling."]
  worked_hours decimal
  registered_by_user_id uuid [not null]
  registered_role varchar [not null]
  consistency_notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table process_quality_records {
  process_quality_record_id uuid [pk]
  section yarn_spinning_section [not null]
  machine_id uuid [ref: > yarn_production_machines.machine_id, note: "Optional when the business records a section-level random check instead of a machine-level check."]
  business_date date [not null]
  shift_code varchar [not null]
  yarn_count_id uuid [ref: > yarn_counts.yarn_count_id, note: "Used when the quality check is tied to a yarn count identity or sample context."]
  quality_method process_quality_method [not null]
  sample_type varchar
  sample_count int
  cv_percent decimal
  tenacity decimal
  elongation decimal
  body_value decimal [note: "Bobbin Winding machine-counter quality value."]
  kilometers decimal [note: "Bobbin Winding machine-counter value."]
  cuts_per_bobbin decimal [note: "Bobbin Winding machine-counter value."]
  result_summary text [note: "Concise result when the exact test values vary by random check or sample method."]
  is_out_of_tolerance boolean
  registered_by_user_id uuid [not null]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table waste_records {
  waste_record_id uuid [pk]
  section yarn_spinning_section [not null]
  machine_group_name varchar [note: "Business group weighed together. Kept as a snapshot instead of adding group tables before needed."]
  business_date date [not null]
  shift_code varchar [not null]
  waste_type waste_record_type [not null]
  weight_kg decimal [not null]
  registered_by_user_id uuid [not null]
  registered_role varchar [not null]
  notes text
  created_at timestamptz [not null]
  updated_at timestamptz
}

Table yarn_production_record_corrections {
  correction_id uuid [pk]
  record_table varchar [not null, note: "Name of the Yarn Production table whose current business record was corrected."]
  record_id uuid [not null]
  corrected_by_user_id uuid [not null]
  corrected_at timestamptz [not null]
  correction_reason text [not null]
  authorization_basis varchar [note: "Operational window, SysAdmin override, or other policy basis."]
  before_values jsonb [not null]
  after_values jsonb [not null]
  created_at timestamptz [not null]
}
